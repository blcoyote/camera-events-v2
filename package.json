{
  "name": "camera-events-v2",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "preinstall": "npx only-allow bun",
    "dev": "vite dev --port 3000",
    "build": "vite build && cp -r src/features/shared/server/frigate/assets .output/server/_ssr/",
    "preview": "bun run build && bun run .output/server",
    "test": "vitest run",
    "verify:bun-bundle": "node scripts/verify-bun-bundle.mjs",
    "audit:advisories": "bun scripts/audit-advisories.ts",
    "lint": "eslint",
    "format": "prettier --check .",
    "check": "prettier --write . && eslint --fix",
    "knip": "knip",
    "prepare": "husky",
    "start": "bun run .output/server"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-devtools": "0.10.8",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.26",
    "@tanstack/router-plugin": "1.168.18",
    "arctic": "^3.7.0",
    "lucide-react": "^1.21.0",
    "mqtt": "^5.15.1",
    "nitro": "^3.0.260610-beta",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "serwist": "^9.5.11",
    "tailwindcss": "^4.3.1",
    "usehooks-ts": "^3.1.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@serwist/build": "^9.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/devtools-vite": "0.8.1",
    "@tanstack/eslint-config": "0.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser": "4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "better-sqlite3": "^12.11.1",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "jsdom": "29.1.1",
    "knip": "^6.20.0",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,md,json,css,yml,yaml}": "prettier --write"
  }
}
