# Google OAuth credentials — get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Session encryption key — must be at least 32 characters
SESSION_SECRET=at-least-32-characters-long-secret-here

# Application URL — set in production to prevent Host header manipulation
# In development, falls back to the request origin automatically
# APP_URL=https://your-app.example.com

# Frigate NVR URL — base URL of your Frigate instance
# Example: http://192.168.1.100:5000 or http://frigate.local:5000
FRIGATE_URL=http://your-frigate-host:5000

# Mock Frigate client — returns randomized data without a real Frigate server
# Useful for frontend development. No FRIGATE_URL needed when enabled.
# FRIGATE_MOCK=true

# MQTT broker — RabbitMQ with MQTT plugin (used for real-time Frigate events)
# In Docker Compose this is set automatically to mqtt://rabbitmq:1883
# MQTT_URL=mqtt://localhost:1883

# RabbitMQ credentials (used by docker-compose for the broker)
# RABBITMQ_USER=frigate
# RABBITMQ_PASS=frigate

# Web Push (VAPID) — generate keys with: npx web-push generate-vapid-keys
# Push notifications are disabled when these are not set (server logs a warning).
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:your-email@example.com
