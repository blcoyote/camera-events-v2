{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "bash hooks/js-fp-review.sh",
            "type": "command"
          },
          {
            "command": "bash hooks/token-efficiency-review.sh",
            "type": "command"
          },
          {
            "command": "bash hooks/eval-compliance-check.sh",
            "type": "command"
          },
          {
            "command": "bash hooks/tdd-guard.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      },
      {
        "hooks": [
          {
            "command": "bash hooks/version-check.sh",
            "type": "command"
          }
        ],
        "matcher": "Read"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "bash hooks/pre-tool-guard.sh",
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "command": "bash hooks/destructive-guard.sh",
            "type": "command"
          },
          {
            "command": "bash hooks/pre-commit-review.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Agent",
      "NotebookEdit",
      "mcp__*"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(git push *)"
    ]
  }
}